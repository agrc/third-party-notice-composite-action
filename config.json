{
  "inputs": [
    "package.json"
  ],
  "output": "./public/ThirdPartyNotices.txt",
  "overwrite": true,
  "ci": true,
  "exclude": [
    "/^@ugrc\\/.*$/"
  ],
  "omitVersions": true,
  "replace": {
    "@esri/arcgis-rest-fetch": "https://raw.githubusercontent.com/Esri/arcgis-rest-js/main/LICENSE",
    "@esri/arcgis-rest-form-data": "https://raw.githubusercontent.com/Esri/arcgis-rest-js/main/LICENSE",
    "type-fest": "https://raw.githubusercontent.com/sindresorhus/type-fest/main/license-mit",
    "from": "https://raw.githubusercontent.com/dominictarr/from/master/LICENSE.MIT",
    "pause-stream": "https://raw.githubusercontent.com/dominictarr/pause-stream/master/LICENCE",
    "through": "https://raw.githubusercontent.com/dominictarr/through/master/LICENSE.MIT"
  }
}
